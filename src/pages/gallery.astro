---
import Layout from '../layouts/Layout.astro';
import Gallery from '../components/Gallery.tsx';

const images = [
  { src: '/gallery/flying-pheasant-mount.png', alt: 'Flying Pheasant Mount on Oak Tree — Bird Taxidermy North Carolina', category: 'Birds' },
  { src: '/gallery/deer-shoulder-mount-semi-sneak-hero.jpg', alt: 'Whitetail Deer Shoulder Mount Semi-Sneak Pose', category: 'Deer' },
  { src: '/gallery/deer-shoulder-mount-habitat-scene-01.jpg', alt: 'Deer Shoulder Mount with Custom Habitat Scene', category: 'Deer' },
  { src: '/gallery/deer-shoulder-mount-habitat-scene-02.jpg', alt: 'Deer Shoulder Mount Habitat Scene Detail', category: 'Deer' },
  { src: '/gallery/whitetail-shoulder-mount-driftwood-base.jpg', alt: 'Whitetail Shoulder Mount on Driftwood Base', category: 'Deer' },
  { src: '/gallery/deer-semi-sneak-mount-pine-base.jpg', alt: 'Deer Semi-Sneak Mount with Pine Base', category: 'Deer' },
  { src: '/gallery/whitetail-shoulder-mount-outdoor-display.png', alt: 'Whitetail Shoulder Mount Outdoor Display', category: 'Deer' },
  { src: '/gallery/whitetail-shoulder-mount-natural-setting-01.jpg', alt: 'Whitetail Shoulder Mount in Natural Setting', category: 'Deer' },
  { src: '/gallery/whitetail-shoulder-mount-natural-setting-02.jpg', alt: 'Whitetail Shoulder Mount Natural Setting Close-Up', category: 'Deer' },
  { src: '/gallery/whitetail-shoulder-mount-natural-setting-03.jpg', alt: 'Whitetail Shoulder Mount Natural Setting Side View', category: 'Deer' },
];
---

<Layout title="Gallery | Twisted Oak Taxidermy" description="Browse our gallery of professional taxidermy work. Deer mounts, bird mounts, predator mounts, and custom pieces. Taxidermy in Mount Airy NC.">
  <section class="py-12 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-charcoal text-center mb-4">
        Gallery
      </h1>
      <p class="text-center text-earth mb-12 max-w-2xl mx-auto">
        Browse our recent work. Each piece is crafted with care and attention to detail.
      </p>

      <Gallery images={images} client:load />
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 bg-charcoal text-cream text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-heading text-2xl md:text-3xl font-bold text-tan mb-4">Like What You See?</h2>
      <p class="text-gray-300 mb-6">Let us bring your next trophy to life.</p>
      <a href="/contact" class="bg-tan hover:bg-tan-light text-charcoal px-8 py-3 rounded font-heading font-semibold tracking-wide transition-colors inline-block">
        Get a Free Quote
      </a>
    </div>
  </section>
</Layout>
