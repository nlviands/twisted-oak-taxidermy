---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Twisted Oak Taxidermy | Deer Taxidermy Mount Airy NC | Local Taxidermist" description="Professional wildlife taxidermy in Mount Airy NC. Deer, predator, bird, and small game mounts. Local taxidermist serving Surry County NC and surrounding areas.">
  <!-- Hero Section -->
  <section class="relative bg-charcoal text-cream overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-charcoal via-charcoal-light to-earth-dark opacity-90"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24 text-center">
      <img src="/logo.jpg" alt="Twisted Oak Taxidermy — Mount Airy, NC — (336) 648-6996" class="max-w-2xl md:max-w-3xl w-full mx-auto" />
      <h1 class="sr-only">Twisted Oak Taxidermy — Professional Taxidermy in Mount Airy, NC</h1>
    </div>
  </section>

  <!-- Tagline + Services -->
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-center text-xl md:text-2xl text-earth-dark font-medium mb-2">
        Mount Airy, North Carolina
      </p>
      <p class="text-center text-lg text-earth max-w-2xl mx-auto mb-6">
        Professional wildlife taxidermy in Mount Airy, North Carolina. Specializing in deer, predators, birds, and small game mounts with quality craftsmanship and attention to detail.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
        <a href="tel:+13366486996" class="bg-tan hover:bg-tan-light text-charcoal px-8 py-3 rounded font-heading text-lg font-semibold tracking-wide transition-colors text-center inline-flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call / Text 336-648-6996
        </a>
        <a href="/gallery" class="border-2 border-charcoal text-charcoal hover:bg-charcoal hover:text-cream px-8 py-3 rounded font-heading text-lg font-semibold tracking-wide transition-colors text-center">
          View Gallery
        </a>
      </div>

      <h2 class="font-heading text-3xl md:text-4xl font-bold text-center text-charcoal mb-4">
        Our Services
      </h2>
      <p class="text-center text-earth mb-12 max-w-2xl mx-auto">
        From whitetail shoulder mounts to predators and waterfowl, we bring your trophy to life with attention to every detail.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow border border-gray-100">
          <div class="w-12 h-12 bg-tan/20 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-tan-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3l3.5 3.5M19 3l-3.5 3.5M12 12l-4-4m4 4l4-4m-4 4v9"/></svg>
          </div>
          <h3 class="font-heading text-xl font-semibold text-charcoal mb-2">Shoulder Mounts</h3>
          <p class="text-earth text-sm leading-relaxed">Classic whitetail and big game shoulder mounts with lifelike detail and natural positioning.</p>
        </div>
        <div class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow border border-gray-100">
          <div class="w-12 h-12 bg-tan/20 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-tan-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          </div>
          <h3 class="font-heading text-xl font-semibold text-charcoal mb-2">Birds & Waterfowl</h3>
          <p class="text-earth text-sm leading-relaxed">Ducks, geese, turkeys, and upland birds. Flying, standing, and tabletop display options.</p>
        </div>
        <div class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow border border-gray-100">
          <div class="w-12 h-12 bg-tan/20 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-tan-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5"/></svg>
          </div>
          <h3 class="font-heading text-xl font-semibold text-charcoal mb-2">Predators</h3>
          <p class="text-earth text-sm leading-relaxed">Coyote, bobcat, and fox life-size mounts. Shoulder mounts and open mouth options available.</p>
        </div>
        <div class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow border border-gray-100">
          <div class="w-12 h-12 bg-tan/20 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-tan-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 007.92 12.446A9 9 0 1112 3z"/></svg>
          </div>
          <h3 class="font-heading text-xl font-semibold text-charcoal mb-2">European Skulls</h3>
          <p class="text-earth text-sm leading-relaxed">Clean, whitened European skull mounts. A modern classic for deer, elk, and other big game.</p>
        </div>
        <div class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow border border-gray-100">
          <div class="w-12 h-12 bg-tan/20 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-tan-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="font-heading text-xl font-semibold text-charcoal mb-2">Full Body Mounts</h3>
          <p class="text-earth text-sm leading-relaxed">Complete life-size mounts for small game, predators, and specialty pieces.</p>
        </div>
        <div class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow border border-gray-100">
          <div class="w-12 h-12 bg-tan/20 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-tan-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
          </div>
          <h3 class="font-heading text-xl font-semibold text-charcoal mb-2">Custom Bases</h3>
          <p class="text-earth text-sm leading-relaxed">Handcrafted habitat bases and display pieces to complement your mount perfectly.</p>
        </div>
      </div>
      <div class="text-center mt-10">
        <a href="/services" class="text-tan-dark hover:text-tan font-semibold inline-flex items-center gap-1 transition-colors">
          View All Services & Pricing
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Gallery Preview -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-center text-charcoal mb-4">
        Recent Work
      </h2>
      <p class="text-center text-earth mb-12">
        A sample of our craftsmanship. Visit the gallery for more.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="aspect-square rounded-lg overflow-hidden">
          <img src="/gallery/deer-shoulder-mount-semi-sneak-hero.jpg" alt="Whitetail deer shoulder mount — semi-sneak pose" class="w-full h-full object-cover hover:scale-105 transition-transform" loading="lazy" />
        </div>
        <div class="aspect-square rounded-lg overflow-hidden">
          <img src="/gallery/whitetail-shoulder-mount-driftwood-base.jpg" alt="Whitetail shoulder mount on driftwood base" class="w-full h-full object-cover hover:scale-105 transition-transform" loading="lazy" />
        </div>
        <div class="aspect-square rounded-lg overflow-hidden">
          <img src="/gallery/deer-shoulder-mount-habitat-scene-01.jpg" alt="Deer shoulder mount with habitat scene" class="w-full h-full object-cover hover:scale-105 transition-transform" loading="lazy" />
        </div>
        <div class="aspect-square rounded-lg overflow-hidden">
          <img src="/gallery/flying-pheasant-mount.png" alt="Flying pheasant mount — bird taxidermy North Carolina" class="w-full h-full object-cover hover:scale-105 transition-transform" loading="lazy" />
        </div>
      </div>
      <div class="text-center mt-8">
        <a href="/gallery" class="bg-charcoal hover:bg-charcoal-light text-cream px-8 py-3 rounded font-heading font-semibold tracking-wide transition-colors inline-block">
          View Full Gallery
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 md:py-20 bg-charcoal text-cream">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-tan mb-4">
        Ready to Preserve Your Trophy?
      </h2>
      <p class="text-gray-300 text-lg mb-8 max-w-2xl mx-auto">
        Drop it off or give us a call. We'll take care of the rest.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+13366486996" class="bg-tan hover:bg-tan-light text-charcoal px-8 py-3 rounded font-heading text-lg font-semibold tracking-wide transition-colors inline-flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call (336) 648-6996
        </a>
        <a href="/contact" class="border-2 border-tan text-tan hover:bg-tan hover:text-charcoal px-8 py-3 rounded font-heading text-lg font-semibold tracking-wide transition-colors">
          Request a Quote
        </a>
      </div>
    </div>
  </section>
</Layout>
