---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "Professional taxidermy services in Mount Airy, NC. Quality shoulder mounts, full body mounts, European skulls, birds, and fish. Serving Surry County and surrounding areas.", image = "/logo.jpg" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Twisted Oak Taxidermy",
  "description": "Professional taxidermy services in Mount Airy, North Carolina",
  "telephone": "+1-336-648-6996",
  "url": "https://twistedoaktaxidermy.com",
  "image": "https://twistedoaktaxidermy.com/logo.jpg",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Mount Airy",
    "addressRegion": "NC",
    "addressCountry": "US"
  },
  "areaServed": [
    "Mount Airy", "Surry County", "Pilot Mountain", "Elkin", "King", "Dobson", "Stuart VA", "Galax VA"
  ],
  "priceRange": "$$",
  "openingHours": "Mo-Sa 08:00-18:00"
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/png" href="/logo.jpg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Navigation -->
    <nav class="bg-charcoal text-cream sticky top-0 z-50 shadow-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 md:h-20">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-3 shrink-0">
            <img src="/logo.jpg" alt="Twisted Oak Taxidermy" class="h-10 md:h-14 w-auto" />
            <span class="font-heading text-lg md:text-xl font-bold text-tan tracking-wide hidden sm:block">
              Twisted Oak Taxidermy
            </span>
          </a>

          <!-- Desktop Nav -->
          <div class="hidden md:flex items-center gap-6">
            <a href="/" class="text-cream hover:text-tan transition-colors font-medium">Home</a>
            <a href="/gallery" class="text-cream hover:text-tan transition-colors font-medium">Gallery</a>
            <a href="/services" class="text-cream hover:text-tan transition-colors font-medium">Services</a>
            <a href="/field-care" class="text-cream hover:text-tan transition-colors font-medium">Field Care</a>
            <a href="/about" class="text-cream hover:text-tan transition-colors font-medium">About</a>
            <a href="/faq" class="text-cream hover:text-tan transition-colors font-medium">FAQ</a>
            <a href="/contact" class="bg-tan hover:bg-tan-light text-charcoal px-5 py-2 rounded font-heading font-semibold tracking-wide transition-colors">
              Get a Quote
            </a>
          </div>

          <!-- Mobile Menu Button -->
          <button id="mobile-menu-btn" class="md:hidden text-cream p-2" aria-label="Toggle menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>

        <!-- Mobile Nav -->
        <div id="mobile-menu" class="hidden md:hidden pb-4">
          <div class="flex flex-col gap-3">
            <a href="/" class="text-cream hover:text-tan transition-colors py-1">Home</a>
            <a href="/gallery" class="text-cream hover:text-tan transition-colors py-1">Gallery</a>
            <a href="/services" class="text-cream hover:text-tan transition-colors py-1">Services</a>
            <a href="/field-care" class="text-cream hover:text-tan transition-colors py-1">Field Care</a>
            <a href="/about" class="text-cream hover:text-tan transition-colors py-1">About</a>
            <a href="/faq" class="text-cream hover:text-tan transition-colors py-1">FAQ</a>
            <a href="/contact" class="bg-tan hover:bg-tan-light text-charcoal px-5 py-2 rounded font-heading font-semibold tracking-wide transition-colors text-center mt-2">
              Get a Quote
            </a>
          </div>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-charcoal text-cream">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Business Info -->
          <div>
            <div class="flex items-center gap-3 mb-4">
              <img src="/logo.jpg" alt="Twisted Oak Taxidermy" class="h-10 w-auto" />
              <span class="font-heading text-xl font-bold text-tan">Twisted Oak Taxidermy</span>
            </div>
            <p class="text-sm text-gray-400 leading-relaxed">
              Professional taxidermy services in Mount Airy, North Carolina.
              Preserving your memories with quality craftsmanship.
            </p>
          </div>

          <!-- Quick Links -->
          <div>
            <h3 class="font-heading text-lg font-semibold text-tan mb-4">Quick Links</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/gallery" class="text-gray-400 hover:text-tan transition-colors">Gallery</a></li>
              <li><a href="/services" class="text-gray-400 hover:text-tan transition-colors">Services & Pricing</a></li>
              <li><a href="/field-care" class="text-gray-400 hover:text-tan transition-colors">Field Care Guide</a></li>
              <li><a href="/faq" class="text-gray-400 hover:text-tan transition-colors">FAQ</a></li>
              <li><a href="/contact" class="text-gray-400 hover:text-tan transition-colors">Contact</a></li>
            </ul>
          </div>

          <!-- Contact Info -->
          <div>
            <h3 class="font-heading text-lg font-semibold text-tan mb-4">Contact</h3>
            <ul class="space-y-2 text-sm text-gray-400">
              <li>
                <a href="tel:+13366486996" class="hover:text-tan transition-colors flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                  (336) 648-6996
                </a>
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                Mount Airy, NC
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Mon-Sat: 8AM - 6PM
              </li>
            </ul>
          </div>
        </div>

        <div class="border-t border-gray-700 mt-8 pt-8 text-center text-sm text-gray-500">
          <p>&copy; {new Date().getFullYear()} Twisted Oak Taxidermy. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <!-- Mobile Menu Script -->
    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
